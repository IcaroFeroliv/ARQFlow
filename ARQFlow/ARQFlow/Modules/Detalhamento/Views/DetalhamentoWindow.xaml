<Window x:Class="ARQFlow.Modules.Detalhamento.Views.DetalhamentoWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARQ Flow - Criar Elevações" Height="500" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="15">
        <StackPanel>
            <!-- Opção 1: Seleção -->
            <GroupBox Header="1. Seleção de Ambientes" Margin="0,0,0,10" Padding="5">
                <StackPanel>
                    <RadioButton x:Name="RbSelecionar" Content="Selecionar ambientes manualmente" Margin="0,5"/>
                    <RadioButton x:Name="RbTodos" Content="Pegar todos os ambientes do projeto" Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <!-- Opção 2: Modelo de Vista -->
            <GroupBox Header="2. Modelo de Vista (View Template)" Margin="0,0,0,10" Padding="5">
                <ComboBox x:Name="CmbViewTemplates" DisplayMemberPath="Name" SelectedValuePath="Id" Margin="0,5"/>
            </GroupBox>

            <!-- Opção 3: Nomenclatura -->
            <GroupBox Header="3. Sufixo das Elevações" Margin="0,0,0,10" Padding="5">
                <StackPanel>
                    <RadioButton x:Name="RbAlfabetico" Content="Alfabético (Ex: Sala - A, Sala - B)" Margin="0,5"/>
                    <RadioButton x:Name="RbNumerico" Content="Numérico (Ex: Sala - 1, Sala - 2)" Margin="0,5"/>
                    <RadioButton x:Name="RbDirecao" Content="Direção (Ex: Sala - Norte, Sala - Leste)" Margin="0,5"/>
                </StackPanel>
            </GroupBox>

            <!-- Opção 4: Lados da Elevação -->
            <GroupBox Header="4. Lados a Criar" Margin="0,0,0,15" Padding="5">
                <UniformGrid Columns="2">
                    <CheckBox x:Name="ChkLado0" Content="Lado 1 (Cima/Norte)" Margin="0,5"/>
                    <CheckBox x:Name="ChkLado1" Content="Lado 2 (Esq./Oeste)" Margin="0,5"/>
                    <CheckBox x:Name="ChkLado2" Content="Lado 3 (Baixo/Sul)" Margin="0,5"/>
                    <CheckBox x:Name="ChkLado3" Content="Lado 4 (Dir./Leste)" Margin="0,5"/>
                </UniformGrid>
            </GroupBox>

            <!-- Botões -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Width="80" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button Content="Avançar" Width="80" Click="BtnAvancar_Click" Background="#007ACC" Foreground="White"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>