<Window x:Class="ARQFlow.Modules.Modelagem.Views.RecorteParedeView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recortar Paredes por Vínculo"
        Height="470" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#EDEEF0"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Botão primário (azul) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"   Value="#2563EB"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="12.5"/>
            <Setter Property="Height"       Value="36"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#C4C9D4"/>
                                <Setter Property="Foreground" Value="#8E95A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário (branco com borda) -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#D0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox limpo -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Border Background="Transparent" BorderThickness="0"/>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1F2329"/>
            <Setter Property="BorderBrush"     Value="#D0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="10,0,0,0"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- CheckBox refinado -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"             Value="#374151"/>
            <Setter Property="FontSize"               Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"                 Value="0,5,0,5"/>
            <Setter Property="Cursor"                 Value="Hand"/>
        </Style>

        <!-- Label de seção -->
        <Style x:Key="LblSecao" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="10.5"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#6B7280"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <!-- Sombra interna leve na borda superior colorida -->
    <Border Background="#EDEEF0" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <!-- Faixa colorida topo -->
                <RowDefinition Height="*"/>
                <!-- Conteúdo -->
            </Grid.RowDefinitions>

            <!-- ── Faixa azul no topo (identidade visual) ─────────────────── -->
            <Border Grid.Row="0" Background="#2563EB"/>

            <!-- ── Conteúdo principal ─────────────────────────────────────── -->
            <Grid Grid.Row="1" Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Cabeçalho -->
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Vínculo label -->
                    <RowDefinition Height="Auto"/>
                    <!-- Vínculo combo -->
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Categorias label -->
                    <RowDefinition Height="Auto"/>
                    <!-- Categorias card -->
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <!-- Tolerância label -->
                    <RowDefinition Height="Auto"/>
                    <!-- Slider -->
                    <RowDefinition Height="*"/>
                    <!-- Flex -->
                    <RowDefinition Height="Auto"/>
                    <!-- Botões -->
                </Grid.RowDefinitions>

                <!-- ── Cabeçalho ──────────────────────────────────────────── -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Recortar Paredes"
                               FontSize="17" FontWeight="Bold"
                               Foreground="#1F2329"/>
                    <TextBlock Text="Gera aberturas nas paredes com base em vínculos Revit"
                               FontSize="11.5" Foreground="#6B7280"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- ── Linha divisória ────────────────────────────────────── -->
                <Border Grid.Row="1" BorderBrush="#D0D3D8" BorderThickness="0,0,0,1"
                        VerticalAlignment="Center"/>

                <!-- ── Vínculo de referência ──────────────────────────────── -->
                <TextBlock Grid.Row="2" Text="VÍNCULO DE REFERÊNCIA"
                           Style="{StaticResource LblSecao}"/>

                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="CmbLinks" Grid.Column="0"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"
                              ToolTip="Selecione o vínculo Revit (estrutural, MEP, etc.)"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource BtnSecondary}"
                            Width="88" Click="BtnRefresh_Click"
                            ToolTip="Recarregar lista de vínculos">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺" FontSize="13" Margin="0,0,5,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Atualizar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ── Categorias ─────────────────────────────────────────── -->
                <TextBlock Grid.Row="5" Text="CATEGORIAS DO VÍNCULO"
                           Style="{StaticResource LblSecao}"/>

                <Border Grid.Row="6"
                        Background="White"
                        BorderBrush="#D0D3D8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="ChkEstrutura"  Grid.Row="0" Grid.Column="0"
                                  Content="Estrutura" IsChecked="True"/>
                        <CheckBox x:Name="ChkDutos"      Grid.Row="0" Grid.Column="1"
                                  Content="Dutos HVAC"/>
                        <CheckBox x:Name="ChkTubulacoes" Grid.Row="1" Grid.Column="0"
                                  Content="Tubulações"/>
                        <CheckBox x:Name="ChkEletrico"   Grid.Row="1" Grid.Column="1"
                                  Content="Eletrocalhas"/>
                    </Grid>
                </Border>

                <!-- ── Tolerância ─────────────────────────────────────────── -->
                <Grid Grid.Row="8">
                    <TextBlock Text="FOLGA DA ABERTURA"
                               Style="{StaticResource LblSecao}"
                               VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right"
                            Background="#2563EB"
                            CornerRadius="4"
                            Padding="8,2">
                        <TextBlock>
                            <Run x:Name="RunTolerancia" Text="2"
                                 Foreground="White" FontWeight="Bold" FontSize="12"/>
                            <Run Text=" cm" Foreground="#BFDBFE" FontSize="11"/>
                        </TextBlock>
                    </Border>
                </Grid>

                <Slider Grid.Row="9" x:Name="SliderTolerancia"
                        Minimum="0" Maximum="10" Value="2"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Foreground="#2563EB"
                        ValueChanged="SliderTolerancia_ValueChanged"/>

                <!-- ── Botões ──────────────────────────────────────────────── -->
                <Grid Grid.Row="11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource BtnSecondary}"
                            Content="Cancelar"
                            Click="BtnCancelar_Click"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource BtnPrimary}"
                            x:Name="BtnExecutar"
                            Click="BtnExecutar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="10" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Executar Recortes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>

