<Window x:Class="ARQFlow.Modules.Modelagem.Views.RecortePisoView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recorte de Pisos x Hidro"
        Height="420" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#EDEEF0"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Botão primário (azul) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#C4C9D4"/>
                                <Setter Property="Foreground" Value="#8E95A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário (branco com borda) -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#D0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox limpo -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TextBox limpo -->
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Label de seção -->
        <Style x:Key="LblSecao" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <Border Background="#EDEEF0" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Faixa azul identidade visual -->
            <Border Grid.Row="0" Background="#2563EB"/>

            <!-- Conteúdo principal -->
            <Grid Grid.Row="1" Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Recorte de Pisos"
                               FontSize="17" FontWeight="Bold" Foreground="#1F2329"/>
                    <TextBlock Text="Gera recortes nos pisos com base em vínculo de hidro"
                               FontSize="11.5" Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Divisória -->
                <Border Grid.Row="1" BorderBrush="#D0D3D8" BorderThickness="0,0,0,1"
                        VerticalAlignment="Center"/>

                <!-- Vínculo -->
                <TextBlock Grid.Row="2" Text="VÍNCULO DE HIDRO"
                           Style="{StaticResource LblSecao}"/>

                <ComboBox x:Name="ComboLinks" Grid.Row="3"
                          ToolTip="Selecione o vínculo de hidráulica"/>

                <!-- Parâmetros -->
                <TextBlock Grid.Row="5" Text="PARÂMETROS"
                           Style="{StaticResource LblSecao}"/>

                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Folga (cm)"
                                   FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtFolga" Text="2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Tolerância (cm)"
                                   FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtTolerancia" Text="1"/>
                    </StackPanel>
                </Grid>

                <!-- Volume mínimo -->
                <TextBlock Grid.Row="8" Text="FILTRO DE VOLUME"
                           Style="{StaticResource LblSecao}"/>

                <StackPanel Grid.Row="9">
                    <TextBlock Text="Volume mínimo (m³)"
                               FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtVolumeMin" Text="0.001"/>
                </StackPanel>

                <!-- Botões -->
                <Grid Grid.Row="11">
                    <Button Style="{StaticResource BtnPrimary}"
                            Click="BtnExecutar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="10" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Executar Recortes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
