<Window x:Class="ARQFlow.Modules.Documentacao.Views.CotarAmbientesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cotar Ambientes"
        Height="640" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#EDEEF0"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Botão primário (azul) -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#C4C9D4"/>
                                <Setter Property="Foreground" Value="#8E95A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botão secundário (branco com borda) -->
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#D0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox limpo -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- TextBox limpo -->
        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- RadioButton refinado -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground"               Value="#374151"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"                   Value="0,5,0,5"/>
            <Setter Property="Cursor"                   Value="Hand"/>
        </Style>

        <!-- Label de seção -->
        <Style x:Key="LblSecao" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

    </Window.Resources>

    <Border Background="#EDEEF0" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Faixa azul identidade visual -->
            <Border Grid.Row="0" Background="#2563EB"/>

            <!-- Conteúdo principal -->
            <Grid Grid.Row="1" Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- 0: Cabeçalho -->
                    <RowDefinition Height="18"/>
                    <!-- 1: Divisória -->
                    <RowDefinition Height="Auto"/>
                    <!-- 2: Família de cota label -->
                    <RowDefinition Height="Auto"/>
                    <!-- 3: ComboBox -->
                    <RowDefinition Height="18"/>
                    <!-- 4: Espaço -->
                    <RowDefinition Height="Auto"/>
                    <!-- 5: Ambientes label -->
                    <RowDefinition Height="Auto"/>
                    <!-- 6: Card de modo -->
                    <RowDefinition Height="18"/>
                    <!-- 7: Espaço -->
                    <RowDefinition Height="Auto"/>
                    <!-- 8: Distância label -->
                    <RowDefinition Height="Auto"/>
                    <!-- 9: Distância input -->
                    <RowDefinition Height="16"/>
                    <!-- 10: Espaço -->
                    <RowDefinition Height="Auto"/>
                    <!-- 11: Posição H label -->
                    <RowDefinition Height="Auto"/>
                    <!-- 12: Posição H card -->
                    <RowDefinition Height="16"/>
                    <!-- 13: Espaço -->
                    <RowDefinition Height="Auto"/>
                    <!-- 14: Posição V label -->
                    <RowDefinition Height="Auto"/>
                    <!-- 15: Posição V card -->
                    <RowDefinition Height="*"/>
                    <!-- 16: Flex -->
                    <RowDefinition Height="Auto"/>
                    <!-- 17: Botões -->
                </Grid.RowDefinitions>

                <!-- ── Cabeçalho ──────────────────────────────────────────── -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Cotar Ambientes"
                               FontSize="17" FontWeight="Bold" Foreground="#1F2329"/>
                    <TextBlock Text="Insere cotas de largura e profundidade nos ambientes"
                               FontSize="11.5" Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- ── Divisória ─────────────────────────────────────────── -->
                <Border Grid.Row="1" BorderBrush="#D0D3D8" BorderThickness="0,0,0,1"
                        VerticalAlignment="Center"/>

                <!-- ── Família de Cota ────────────────────────────────────── -->
                <TextBlock Grid.Row="2" Text="FAMÍLIA DE COTA"
                           Style="{StaticResource LblSecao}"/>

                <ComboBox Grid.Row="3" x:Name="CmbDimType"
                          DisplayMemberPath="Name"
                          ToolTip="Selecione o tipo de dimensão linear a usar nas cotas"/>

                <!-- ── Ambientes a cotar ──────────────────────────────────── -->
                <TextBlock Grid.Row="5" Text="AMBIENTES A COTAR"
                           Style="{StaticResource LblSecao}"/>

                <Border Grid.Row="6"
                        Background="White"
                        BorderBrush="#D0D3D8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,8">
                    <StackPanel>
                        <RadioButton x:Name="RdoTodos"
                                     Content="Todos os visíveis na planta atual"
                                     IsChecked="True"
                                     GroupName="ModoAmbientes"/>
                        <RadioButton x:Name="RdoSelecionar"
                                     Content="Selecionar manualmente"
                                     GroupName="ModoAmbientes"/>
                    </StackPanel>
                </Border>

                <!-- ── Distância da parede ───────────────────────────────── -->
                <TextBlock Grid.Row="8" Text="DISTÂNCIA DA PAREDE"
                           Style="{StaticResource LblSecao}"/>

                <Grid Grid.Row="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" x:Name="TxtDistancia" Text="30"
                             ToolTip="Distância em centímetros da face da parede até a linha de cota"/>

                    <Border Grid.Column="2"
                            Background="#F3F4F6"
                            BorderBrush="#D0D3D8"
                            BorderThickness="1"
                            CornerRadius="5"
                            Height="34"
                            Padding="12,0">
                        <TextBlock Text="cm" FontSize="12.5" Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- ── Posição cota horizontal ──────────────────────────── -->
                <TextBlock Grid.Row="11" Text="COTA HORIZONTAL"
                           Style="{StaticResource LblSecao}"/>

                <Border Grid.Row="12"
                        Background="White"
                        BorderBrush="#D0D3D8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RdoHAbaixo"
                                     Content="Abaixo"
                                     IsChecked="True"
                                     GroupName="PosH"
                                     Margin="0,0,20,0"/>
                        <RadioButton x:Name="RdoHAcima"
                                     Content="Acima"
                                     GroupName="PosH"/>
                    </StackPanel>
                </Border>

                <!-- ── Posição cota vertical ─────────────────────────────── -->
                <TextBlock Grid.Row="14" Text="COTA VERTICAL"
                           Style="{StaticResource LblSecao}"/>

                <Border Grid.Row="15"
                        Background="White"
                        BorderBrush="#D0D3D8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="RdoVEsquerda"
                                     Content="Esquerda"
                                     IsChecked="True"
                                     GroupName="PosV"
                                     Margin="0,0,20,0"/>
                        <RadioButton x:Name="RdoVDireita"
                                     Content="Direita"
                                     GroupName="PosV"/>
                    </StackPanel>
                </Border>

                <!-- ── Botões ─────────────────────────────────────────────── -->
                <Grid Grid.Row="17">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource BtnSecondary}"
                            Content="Cancelar"
                            Click="BtnCancelar_Click"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource BtnPrimary}"
                            Click="BtnExecutar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="10" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Executar Cotas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>

