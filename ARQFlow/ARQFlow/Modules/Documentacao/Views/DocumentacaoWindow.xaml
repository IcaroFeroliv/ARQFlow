<Window x:Class="ARQFlow.Modules.Documentacao.Views.DocumentacaoWindow"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração de Documentação"
        Height="580" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#EDEEF0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#C4C9D4"/>
                                <Setter Property="Foreground" Value="#8E95A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#D0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="14,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"               Value="#374151"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"                   Value="0,6,0,6"/>
            <Setter Property="Cursor"                   Value="Hand"/>
        </Style>

        <Style x:Key="LblSecao" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LblCampo" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

    </Window.Resources>

    <Border Background="#EDEEF0" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2563EB"/>

            <Grid Grid.Row="1" Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Configuração de Documentação"
                               FontSize="17" FontWeight="Bold" Foreground="#1F2329"/>
                    <TextBlock Text="Configura tags de portas, janelas e símbolos de nível"
                               FontSize="11.5" Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#D0D3D8" BorderThickness="0,0,0,1"
                        VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Text="TAGS DE PORTAS" Style="{StaticResource LblSecao}"/>
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Família da Tag" Style="{StaticResource LblCampo}"/>
                        <ComboBox x:Name="cbPortas" DisplayMemberPath="Name"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Posição" Style="{StaticResource LblCampo}"/>
                        <ComboBox x:Name="cbPosPorta">
                            <ComboBoxItem Content="Acima"/>
                            <ComboBoxItem Content="Centro" IsSelected="True"/>
                            <ComboBoxItem Content="Abaixo"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="5" Text="TAGS DE JANELAS" Style="{StaticResource LblSecao}"/>
                <StackPanel Grid.Row="6">
                    <TextBlock Text="Família da Tag" Style="{StaticResource LblCampo}"/>
                    <ComboBox x:Name="cbJanelas" DisplayMemberPath="Name"/>
                </StackPanel>

                <TextBlock Grid.Row="8" Text="NÍVEIS DE PISO" Style="{StaticResource LblSecao}"/>
                <StackPanel Grid.Row="9">
                    <TextBlock Text="Símbolo de Nível" Style="{StaticResource LblCampo}"/>
                    <ComboBox x:Name="cbNiveis" DisplayMemberPath="Name"/>
                </StackPanel>

                <Border Grid.Row="11"
                        Background="White"
                        BorderBrush="#D0D3D8"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14,6">
                    <StackPanel>
                        <CheckBox x:Name="chkAtivarChamada" Content="Ativar chamada de detalhe" IsChecked="True"/>
                        <CheckBox x:Name="chkRessalto" Content="Ativar ressalto da chamada" IsChecked="False"/>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="13">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Style="{StaticResource BtnSecondary}"
                            Content="Cancelar"
                            Click="BtnCancelar_Click"/>

                    <Button Grid.Column="2"
                            Style="{StaticResource BtnPrimary}"
                            Click="BtnExecutar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="10" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Executar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>