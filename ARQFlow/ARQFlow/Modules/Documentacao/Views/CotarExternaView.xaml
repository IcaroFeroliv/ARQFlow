<Window x:Class="ARQFlow.Modules.Documentacao.Views.CotarExternaView"
                xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cotar Externa"
        Height="600" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#EDEEF0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background"      Value="#2563EB"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" Padding="14,0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#C4C9D4"/>
                                <Setter Property="Foreground" Value="#8E95A0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#374151"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderBrush"     Value="#D0D3D8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="14,0" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="Foreground"               Value="#1F2329"/>
            <Setter Property="BorderBrush"              Value="#D0D3D8"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="Height"                   Value="34"/>
            <Setter Property="Padding"                  Value="10,0,0,0"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground"               Value="#374151"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin"                   Value="0,5,0,5"/>
            <Setter Property="Cursor"                   Value="Hand"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground"               Value="#374151"/>
            <Setter Property="FontSize"                 Value="12.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor"                   Value="Hand"/>
        </Style>

        <Style x:Key="LblSecao" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>
    </Window.Resources>

    <Border Background="#EDEEF0" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="5"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2563EB"/>

            <Grid Grid.Row="1" Margin="24,20,24,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Cotar Externa"
                               FontSize="17" FontWeight="Bold" Foreground="#1F2329"/>
                    <TextBlock Text="Insere cotas gerais da extensão total do projeto"
                               FontSize="11.5" Foreground="#6B7280" Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Row="1" BorderBrush="#D0D3D8" BorderThickness="0,0,0,1"
                        VerticalAlignment="Center"/>

                <!-- Família de Cota -->
                <TextBlock Grid.Row="2" Text="FAMÍLIA DE COTA" Style="{StaticResource LblSecao}"/>
                <ComboBox Grid.Row="3" x:Name="CmbDimType" DisplayMemberPath="Name"
                          ToolTip="Selecione o tipo de dimensão linear a usar nas cotas"/>

                <!-- Paredes a considerar -->
                <TextBlock Grid.Row="5" Text="PAREDES A CONSIDERAR" Style="{StaticResource LblSecao}"/>
                <Border Grid.Row="6" Background="White" BorderBrush="#D0D3D8" BorderThickness="1"
                        CornerRadius="6" Padding="14,8">
                    <StackPanel>
                        <RadioButton x:Name="RdoTodos"
                                     Content="Detectar automaticamente o grupo principal"
                                     IsChecked="True" GroupName="Modo"/>
                        <RadioButton x:Name="RdoSelecionar"
                                     Content="Selecionar manualmente"
                                     GroupName="Modo"/>
                    </StackPanel>
                </Border>

                <!-- Distância -->
                <TextBlock Grid.Row="8" Text="DISTÂNCIA DA COTA" Style="{StaticResource LblSecao}"/>
                <Grid Grid.Row="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="TxtDistancia" Text="100"
                             ToolTip="Distância em centímetros do envelope do projeto até a linha de cota"/>
                    <Border Grid.Column="2" Background="#F3F4F6" BorderBrush="#D0D3D8"
                            BorderThickness="1" CornerRadius="5" Height="34" Padding="12,0">
                        <TextBlock Text="cm" FontSize="12.5" Foreground="#6B7280"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Cotas a criar -->
                <TextBlock Grid.Row="11" Text="COTAS A CRIAR" Style="{StaticResource LblSecao}"/>
                <Border Grid.Row="12" Background="White" BorderBrush="#D0D3D8" BorderThickness="1"
                        CornerRadius="6" Padding="14,12">
                    <StackPanel>
                        <CheckBox x:Name="ChkHorizontal" IsChecked="True" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Cota Horizontal" FontSize="12.5" Foreground="#374151"/>
                                <TextBlock Text="Largura geral do projeto — linha posicionada abaixo"
                                           FontSize="10.5" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                        <CheckBox x:Name="ChkVertical" IsChecked="True">
                            <StackPanel>
                                <TextBlock Text="Cota Vertical" FontSize="12.5" Foreground="#374151"/>
                                <TextBlock Text="Altura geral do projeto — linha posicionada à esquerda"
                                           FontSize="10.5" Foreground="#9CA3AF" Margin="0,2,0,0"/>
                            </StackPanel>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- Nota informativa -->
                <TextBlock Grid.Row="13"
                           Text="Funciona para projetos alinhados com os eixos X/Y da vista."
                           FontSize="10.5" Foreground="#9CA3AF"
                           Margin="2,8,0,0" TextWrapping="Wrap"/>

                <!-- Botões -->
                <Grid Grid.Row="14" VerticalAlignment="Bottom">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource BtnSecondary}"
                            Content="Cancelar" Click="BtnCancelar_Click"/>

                    <Button Grid.Column="2" Style="{StaticResource BtnPrimary}"
                            Click="BtnExecutar_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Executar Cotas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
